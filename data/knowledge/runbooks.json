[
  {
    "id": "high-cpu",
    "title": "CPU 使用率过高",
    "category": "linux",
    "severity": "high",
    "symptoms": ["cpu high", "CPU高", "负载高", "load average", "top"],
    "description": "服务器 CPU 使用率持续过高，影响服务性能",
    "diagnosis": {
      "commands": [
        "top -bn1 | head -20",
        "ps aux --sort=-%cpu | head -10",
        "pidstat -u 1 5",
        "vmstat 1 5",
        "mpstat -P ALL 1 5"
      ],
      "log_files": ["/var/log/syslog", "/var/log/messages"],
      "metrics": ["cpu_usage", "load_average", "process_count"]
    },
    "root_causes": [
      {"cause": "Java GC 频繁", "probability": 0.4, "evidence": "jstat -gc 显示 Full GC 频繁"},
      {"cause": "应用死循环", "probability": 0.3, "evidence": "某进程 CPU 占用 100%"},
      {"cause": "挖矿病毒", "probability": 0.1, "evidence": "未知进程占用大量 CPU"},
      {"cause": "配置不当", "probability": 0.2, "evidence": "线程数过多或配置不合理"}
    ],
    "fixes": [
      {
        "step": 1,
        "action": "定位高 CPU 进程",
        "command": "ps aux --sort=-%cpu | head -5",
        "expected": "找到占用 CPU 最高的进程"
      },
      {
        "step": 2,
        "action": "分析进程详情",
        "command": "top -Hp <PID>",
        "expected": "查看进程的线程 CPU 使用情况"
      },
      {
        "step": 3,
        "action": "Java 应用检查 GC",
        "command": "jstat -gc <PID> 1000 10",
        "expected": "检查 GC 频率和耗时"
      },
      {
        "step": 4,
        "action": "清理缓存",
        "command": "sync && echo 3 > /proc/sys/vm/drop_caches",
        "expected": "释放系统缓存"
      },
      {
        "step": 5,
        "action": "重启服务（如需要）",
        "command": "systemctl restart <service>",
        "expected": "服务恢复正常"
      }
    ],
    "verification": "top -bn1 | grep 'Cpu(s)' 确认 CPU 使用率下降",
    "prevention": [
      "设置 CPU 告警阈值",
      "定期检查应用性能",
      "优化 JVM 参数"
    ],
    "tags": ["linux", "performance", "cpu"]
  },
  {
    "id": "memory-leak",
    "title": "内存泄漏",
    "category": "linux",
    "severity": "high",
    "symptoms": ["memory leak", "内存泄漏", "OOM", "内存不足"],
    "description": "应用程序内存使用持续增长，可能导致 OOM",
    "diagnosis": {
      "commands": [
        "free -h",
        "ps aux --sort=-%mem | head -10",
        "cat /proc/meminfo | head -10",
        "jmap -heap <PID>",
        "jstat -gc <PID> 1000 10"
      ],
      "log_files": ["/var/log/syslog", "/var/log/messages"],
      "metrics": ["memory_usage", "swap_usage", "process_memory"]
    },
    "root_causes": [
      {"cause": "Java 内存泄漏", "probability": 0.5, "evidence": "Java 堆内存持续增长"},
      {"cause": "应用内存泄漏", "probability": 0.3, "evidence": "进程内存持续增长"},
      {"cause": "配置不当", "probability": 0.2, "evidence": "内存限制过低"}
    ],
    "fixes": [
      {
        "step": 1,
        "action": "检查内存使用",
        "command": "free -h && ps aux --sort=-%mem | head -10",
        "expected": "找到内存占用最高的进程"
      },
      {
        "step": 2,
        "action": "Java 应用生成堆转储",
        "command": "jmap -dump:live,format=b,file=/tmp/heap.hprof <PID>",
        "expected": "生成堆转储文件用于分析"
      },
      {
        "step": 3,
        "action": "分析内存使用",
        "command": "jmap -heap <PID>",
        "expected": "查看堆内存使用情况"
      },
      {
        "step": 4,
        "action": "重启服务",
        "command": "systemctl restart <service>",
        "expected": "释放内存，服务恢复正常"
      }
    ],
    "verification": "free -h 确认内存使用正常",
    "prevention": [
      "设置内存告警阈值",
      "定期进行内存分析",
      "优化应用内存使用"
    ],
    "tags": ["linux", "memory", "oom"]
  },
  {
    "id": "disk-full",
    "title": "磁盘空间不足",
    "category": "linux",
    "severity": "critical",
    "symptoms": ["disk full", "磁盘满", "No space left", "ENOSPC"],
    "description": "磁盘空间不足，可能导致服务无法写入数据",
    "diagnosis": {
      "commands": [
        "df -h",
        "du -sh /* | sort -rh | head -10",
        "find / -type f -size +100M | head -20",
        "lsof +L1"
      ],
      "log_files": ["/var/log/syslog"],
      "metrics": ["disk_usage", "inode_usage"]
    },
    "root_causes": [
      {"cause": "日志文件增长", "probability": 0.4, "evidence": "/var/log 目录占用大量空间"},
      {"cause": "临时文件未清理", "probability": 0.3, "evidence": "/tmp 或应用临时目录"},
      {"cause": "Docker 镜像/容器", "probability": 0.2, "evidence": "Docker 数据目录"},
      {"cause": "核心转储文件", "probability": 0.1, "evidence": "core 文件占用空间"}
    ],
    "fixes": [
      {
        "step": 1,
        "action": "查看磁盘使用情况",
        "command": "df -h",
        "expected": "确认哪个分区满"
      },
      {
        "step": 2,
        "action": "查找大文件",
        "command": "du -sh /* 2>/dev/null | sort -rh | head -10",
        "expected": "找到占用空间最大的目录"
      },
      {
        "step": 3,
        "action": "清理日志文件",
        "command": "find /var/log -name '*.gz' -mtime +30 -delete",
        "expected": "释放日志空间"
      },
      {
        "step": 4,
        "action": "清理 Docker",
        "command": "docker system prune -f",
        "expected": "清理未使用的 Docker 资源"
      },
      {
        "step": 5,
        "action": "清理 journal",
        "command": "journalctl --vacuum-time=7d",
        "expected": "清理旧的 journal 日志"
      }
    ],
    "verification": "df -h 确认磁盘使用率下降",
    "prevention": [
      "配置日志轮转",
      "定期清理临时文件",
      "设置磁盘告警"
    ],
    "tags": ["linux", "disk", "storage"]
  },
  {
    "id": "pod-crashloop",
    "title": "Pod CrashLoopBackOff",
    "category": "kubernetes",
    "severity": "high",
    "symptoms": ["CrashLoopBackOff", "pod crash", "pod重启", "OOMKilled"],
    "description": "Kubernetes Pod 反复重启，处于 CrashLoopBackOff 状态",
    "diagnosis": {
      "commands": [
        "kubectl get pods -o wide",
        "kubectl describe pod <pod>",
        "kubectl logs <pod> --previous",
        "kubectl get events --sort-by=.lastTimestamp"
      ],
      "log_files": [],
      "metrics": ["pod_restarts", "pod_status"]
    },
    "root_causes": [
      {"cause": "应用启动失败", "probability": 0.4, "evidence": "日志显示启动错误"},
      {"cause": "OOMKilled", "probability": 0.3, "evidence": "describe 显示 OOMKilled"},
      {"cause": "配置错误", "probability": 0.2, "evidence": "环境变量或配置缺失"},
      {"cause": "依赖服务不可用", "probability": 0.1, "evidence": "无法连接数据库或 Redis"}
    ],
    "fixes": [
      {
        "step": 1,
        "action": "查看 Pod 状态",
        "command": "kubectl get pods -o wide",
        "expected": "确认 Pod 状态为 CrashLoopBackOff"
      },
      {
        "step": 2,
        "action": "查看 Pod 详情",
        "command": "kubectl describe pod <pod>",
        "expected": "查看重启原因和事件"
      },
      {
        "step": 3,
        "action": "查看日志",
        "command": "kubectl logs <pod> --previous",
        "expected": "查看上一次崩溃的日志"
      },
      {
        "step": 4,
        "action": "检查资源限制",
        "command": "kubectl get pod <pod> -o yaml | grep -A 5 resources",
        "expected": "检查内存和 CPU 限制"
      },
      {
        "step": 5,
        "action": "重启 Deployment",
        "command": "kubectl rollout restart deployment/<name>",
        "expected": "Pod 重新部署并恢复正常"
      }
    ],
    "verification": "kubectl get pods 确认 Pod 状态为 Running",
    "prevention": [
      "设置合理的资源限制",
      "配置健康检查",
      "监控 Pod 重启次数"
    ],
    "tags": ["kubernetes", "pod", "crash"]
  },
  {
    "id": "redis-connection",
    "title": "Redis 连接失败",
    "category": "database",
    "severity": "high",
    "symptoms": ["redis connection", "Redis连接失败", "ConnectionPoolTimeout", "连接超时"],
    "description": "无法连接到 Redis 服务器或连接池耗尽",
    "diagnosis": {
      "commands": [
        "redis-cli ping",
        "redis-cli info clients",
        "redis-cli config get maxclients",
        "netstat -tlnp | grep 6379",
        "redis-cli info memory"
      ],
      "log_files": ["/var/log/redis/redis.log"],
      "metrics": ["redis_connections", "redis_memory", "redis_ops"]
    },
    "root_causes": [
      {"cause": "Redis 服务未启动", "probability": 0.2, "evidence": "redis-cli ping 无响应"},
      {"cause": "连接池耗尽", "probability": 0.4, "evidence": "ConnectionPoolTimeout"},
      {"cause": "网络问题", "probability": 0.2, "evidence": "telnet 无法连接"},
      {"cause": "防火墙阻断", "probability": 0.2, "evidence": "iptables 规则"}
    ],
    "fixes": [
      {
        "step": 1,
        "action": "检查 Redis 状态",
        "command": "redis-cli ping",
        "expected": "返回 PONG"
      },
      {
        "step": 2,
        "action": "检查连接数",
        "command": "redis-cli info clients",
        "expected": "查看当前连接数"
      },
      {
        "step": 3,
        "action": "检查网络连通性",
        "command": "telnet <redis-host> 6379",
        "expected": "网络连通"
      },
      {
        "step": 4,
        "action": "重启 Redis",
        "command": "systemctl restart redis",
        "expected": "Redis 重启成功"
      }
    ],
    "verification": "redis-cli ping 返回 PONG",
    "prevention": [
      "监控 Redis 连接数",
      "配置连接池大小",
      "设置连接超时"
    ],
    "tags": ["database", "redis", "connection"]
  },
  {
    "id": "mysql-slow-query",
    "title": "MySQL 慢查询",
    "category": "database",
    "severity": "medium",
    "symptoms": ["slow query", "慢查询", "查询慢", "API 响应慢"],
    "description": "MySQL 查询执行时间过长，影响应用性能",
    "diagnosis": {
      "commands": [
        "mysql -e 'SHOW PROCESSLIST'",
        "mysql -e 'SHOW ENGINE INNODB STATUS'",
        "mysql -e 'SELECT * FROM information_schema.innodb_trx'",
        "mysql -e 'EXPLAIN SELECT ...'"
      ],
      "log_files": ["/var/log/mysql/slow.log"],
      "metrics": ["mysql_queries", "mysql_locks", "mysql_slow_queries"]
    },
    "root_causes": [
      {"cause": "缺少索引", "probability": 0.5, "evidence": "EXPLAIN 显示全表扫描"},
      {"cause": "锁等待", "probability": 0.3, "evidence": "innodb_trx 显示锁等待"},
      {"cause": "查询语句问题", "probability": 0.2, "evidence": "复杂 JOIN 或子查询"}
    ],
    "fixes": [
      {
        "step": 1,
        "action": "查看慢查询日志",
        "command": "tail -100 /var/log/mysql/slow.log",
        "expected": "找到慢查询"
      },
      {
        "step": 2,
        "action": "分析查询执行计划",
        "command": "mysql -e 'EXPLAIN SELECT ...'",
        "expected": "确认是否全表扫描"
      },
      {
        "step": 3,
        "action": "添加索引",
        "command": "mysql -e 'CREATE INDEX idx_xxx ON table(column)'",
        "expected": "查询性能提升"
      }
    ],
    "verification": "查询响应时间恢复正常",
    "prevention": [
      "定期分析慢查询",
      "优化表结构",
      "监控查询性能"
    ],
    "tags": ["database", "mysql", "performance"]
  },
  {
    "id": "nginx-502",
    "title": "Nginx 502 Bad Gateway",
    "category": "web",
    "severity": "high",
    "symptoms": ["502", "Bad Gateway", "nginx 502", "网关错误"],
    "description": "Nginx 返回 502 错误，通常表示后端服务不可用",
    "diagnosis": {
      "commands": [
        "tail -100 /var/log/nginx/error.log",
        "curl -I http://localhost:8080",
        "systemctl status <backend-service>",
        "netstat -tlnp | grep <backend-port>"
      ],
      "log_files": ["/var/log/nginx/error.log", "/var/log/nginx/access.log"],
      "metrics": ["nginx_5xx", "nginx_upstream_status"]
    },
    "root_causes": [
      {"cause": "后端服务未启动", "probability": 0.4, "evidence": "后端服务状态为 inactive"},
      {"cause": "后端服务崩溃", "probability": 0.3, "evidence": "后端进程不存在"},
      {"cause": "连接超时", "probability": 0.2, "evidence": "upstream timed out"},
      {"cause": "端口不匹配", "probability": 0.1, "evidence": "配置的端口未监听"}
    ],
    "fixes": [
      {
        "step": 1,
        "action": "检查 Nginx 错误日志",
        "command": "tail -50 /var/log/nginx/error.log",
        "expected": "找到具体错误原因"
      },
      {
        "step": 2,
        "action": "检查后端服务",
        "command": "systemctl status <backend-service>",
        "expected": "确认后端服务状态"
      },
      {
        "step": 3,
        "action": "重启后端服务",
        "command": "systemctl restart <backend-service>",
        "expected": "后端服务恢复正常"
      },
      {
        "step": 4,
        "action": "重新加载 Nginx",
        "command": "nginx -t && systemctl reload nginx",
        "expected": "Nginx 配置正确并重新加载"
      }
    ],
    "verification": "curl -I http://localhost 返回 200",
    "prevention": [
      "配置健康检查",
      "设置服务自动重启",
      "监控后端服务状态"
    ],
    "tags": ["web", "nginx", "502"]
  },
  {
    "id": "node-notready",
