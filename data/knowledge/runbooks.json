    "category": "kubernetes",
    "severity": "critical",
    "symptoms": ["NodeNotReady", "node not ready", "节点不可用"],
    "description": "Kubernetes Node 状态为 NotReady，影响 Pod 调度",
    "diagnosis": {
      "commands": [
        "kubectl get nodes",
        "kubectl describe node <node>",
        "systemctl status kubelet",
        "journalctl -u kubelet -f"
      ],
      "log_files": ["/var/log/kubelet.log"],
      "metrics": ["node_status", "kubelet_status", "container_runtime"]
    },
    "root_causes": [
      {"cause": "Kubelet 未运行", "probability": 0.4, "evidence": "systemctl status kubelet 显示 inactive"},
      {"cause": "容器运行时故障", "probability": 0.3, "evidence": "containerd 或 docker 未运行"},
      {"cause": "网络问题", "probability": 0.2, "evidence": "节点无法与 API Server 通信"},
      {"cause": "磁盘压力", "probability": 0.1, "evidence": "磁盘空间不足"}
    ],
    "fixes": [
      {
        "step": 1,
        "action": "检查 Kubelet 状态",
        "command": "systemctl status kubelet",
        "expected": "确认 Kubelet 运行状态"
      },
      {
        "step": 2,
        "action": "重启 Kubelet",
        "command": "systemctl restart kubelet",
        "expected": "Kubelet 重启成功"
      },
      {
        "step": 3,
        "action": "检查容器运行时",
        "command": "systemctl status containerd",
        "expected": "容器运行时正常"
      },
      {
        "step": 4,
        "action": "查看 Node 事件",
        "command": "kubectl describe node <node> | grep -A 10 Events",
        "expected": "查看具体事件信息"
      }
    ],
    "verification": "kubectl get nodes 显示 Node 状态为 Ready",
    "prevention": [
      "监控 Node 状态",
      "设置 Kubelet 自动重启",
      "定期检查磁盘空间"
    ],
    "tags": ["kubernetes", "node", "notready"]
  }
