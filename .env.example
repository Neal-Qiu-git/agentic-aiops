# ========================================
# Agentic AIOps 环境配置
# 复制为 .env 后修改
# ========================================

# AI 模型配置
AIOPS_AI_API_KEY=your-api-key-here
AIOPS_AI_PROVIDER=deepseek
AIOPS_AI_MODEL=deepseek-chat

# 服务器配置（JSON 数组格式）
# AIOPS_SERVERS='[{"name":"prod","host":"10.0.0.1","user":"root","port":22}]'

# 服务端口
PORT=3001

# 日志级别
LOG_LEVEL=info
